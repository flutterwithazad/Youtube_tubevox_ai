# Copy this file to .env and fill in your values.
# In Replit, set these via the Secrets panel instead of a .env file.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Your Supabase project URL  (used by: API server, Dashboard, Admin)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key  (used by: Dashboard, Admin)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — KEEP THIS SECRET  (used by: API server only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API Server ─────────────────────────────────────────────────────────────────
# Port for the API server (Replit assigns this automatically per-workflow).
# When running locally, each service needs its own PORT value — set these in
# the shell or per-service .env files, NOT in a shared root .env.
#
#   API server:  PORT=8080
#   Dashboard:   PORT=3000  BASE_PATH=/dashboard/
#   Admin:       PORT=3001  BASE_PATH=/admin/
#
PORT=8080

# Secret used to sign admin JWT tokens  (used by: API server)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# ── Local development only ─────────────────────────────────────────────────────
# The Dashboard and Admin Vite dev servers proxy /api/* requests to this URL.
# On Replit this is handled automatically — you don't need to set it there.
# Locally: set this to wherever your API server is listening.
API_SERVER_URL=http://localhost:8080
