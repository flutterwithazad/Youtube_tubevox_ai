# Copy this file to .env and fill in your values.
# In Replit, set these via the Secrets panel instead of a .env file.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Your Supabase project URL  (used by: API server, Dashboard)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key  (used by: Dashboard)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — KEEP THIS SECRET  (used by: API server only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── API Server ─────────────────────────────────────────────────────────────────
# Port to run the backend on (Replit sets this automatically)
PORT=3001

# Secret used to sign admin JWT tokens  (used by: API server)
ADMIN_JWT_SECRET=change-me-to-a-long-random-string
