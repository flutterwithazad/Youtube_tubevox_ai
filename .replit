modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "YTScraper Landing"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "YTScraper Dashboard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "YTScraper Admin"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "YTScraper Landing"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=22696 BASE_PATH=/ pnpm --filter @workspace/ytscraper-landing run dev"
waitForPort = 22696

[[workflows.workflow]]
name = "YTScraper Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23183 BASE_PATH=/dashboard/ pnpm --filter @workspace/dashboard run dev"
waitForPort = 23183

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "YTScraper Admin"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23744 BASE_PATH=/admin/ pnpm --filter @workspace/admin run dev"
waitForPort = 23744

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_SUPABASE_URL = "https://jxceenqmcyclbxaxvxto.supabase.co"
